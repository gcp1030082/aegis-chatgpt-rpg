PORT=8787

# Local development (default)
AEGIS_STORAGE_DRIVER=file
AEGIS_DATA_DIR=./data

# Production persistence. Set AEGIS_STORAGE_DRIVER=postgres and provide this.
# DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_SSL=true

# Personal deployment protection. Use 16-128 URL-safe characters.
# When set, the endpoint becomes /mcp/<this-secret>.
# AEGIS_MCP_PATH_SECRET=replace-with-a-long-random-secret

# Disabled by default so the legacy HTML is not public in production.
AEGIS_ENABLE_LEGACY_ADMIN=false

# Optional safety limits
AEGIS_MAX_STATE_BYTES=2097152
AEGIS_MAX_DIFF_BYTES=524288
